{
  "server": {
    "listen_address": ":18081",
    "read_header_timeout": "3s",
    "read_timeout": "10s",
    "write_timeout": "15s",
    "idle_timeout": "60s",
    "shutdown_timeout": "10s"
  },
  "auth": {
    "enrollment_license_keys": [
      "replace-with-strong-license-key-001"
    ],
    "require_tls": true,
    "trust_forwarded_proto": false,
    "nonce_ttl": "10m",
    "max_nonces_per_device": 256
  },
  "storage": {
    "path": "./center-data/devices.json"
  },
  "heartbeat": {
    "max_clock_skew": "5m",
    "expected_interval": "1m",
    "missed_heartbeats_for_offline": 3,
    "stale_after": "720h"
  }
}
